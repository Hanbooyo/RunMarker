POSTGRES_DB=stravamate_passport
POSTGRES_USER=stravamate
POSTGRES_PASSWORD=replace-with-local-docker-password

SERVER_PORT=8080
SESSION_TIMEOUT=60m
FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:8080/api/auth/strava/callback

GEOCODING_PROVIDER=nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=RunMarker/0.1 docker-local
GEOCODING_CACHE_COORDINATE_SCALE=3

VITE_API_BASE_URL=http://localhost:8080
VITE_DEMO_MODE=false
